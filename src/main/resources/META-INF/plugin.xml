<idea-plugin>
    <id>com.alianga.idea.deploy</id>
    <name>DeployX</name>
    <vendor email="zml@alianga.com" url="https://github.com/zhengmingliang/DeployX">alianga</vendor>

    <description><![CDATA[
        <p>DeployX - All-in-one remote deployment tool with SSH server management, file sync, auto backup, remote extraction, command execution and terminal integration.</p>
        <ul>
            <li>🖥️ Server management: password/key SSH authentication, connection test, config cloning
            <li>📁 Directory mapping: local/remote mapping with unique IDs
            <li>🔄 Smart transfer: rsync first with AUTO/RSYNC_ONLY/SFTP_ONLY; auto fall back to SFTP
            <li>📤 Batch upload: multi-file merged transfer with relative paths
            <li>🚀 One-click deploy: auto backup, upload, extract, execute commands
            <li>💾 Auto backup: backup before deployment, selective file package
            <li>📦 Auto extract: unzip remote files after upload
            <li>📜 History: per-server logs, history rollback and redeploy
            <li>🖥️ SSH terminal: protocol-level auth opens remote terminal
            <li>📚 Script library: reusable remote SSH commands with parameters, context interpolation and safety checks
        </ul>

        <br>
        <p>全能型远程部署工具 - DeployX：一站式远程部署、自动备份、远程解压、文件同步、SSH 终端集成。</p>
        <ul>
            <li>🖥️ 服务器管理：支持密码/密钥 SSH 认证，支持连接测试与配置复制</li>
            <li>📁 目录映射：本地/远程目录映射，唯一 ID 管理，名称允许重复</li>
            <li>🔄 智能传输：rsync 优先，支持 AUTO / RSYNC_ONLY / SFTP_ONLY；自动降级 SFTP</li>
            <li>📤 批量上传：多文件合并传输，保持相对路径</li>
            <li>🚀 一键部署：自动执行备份、上传、解压和前后置命令</li>
            <li>💾 智能备份：部署前自动备份，支持选择文件打包备份</li>
            <li>📦 自动解压：上传后可按配置自动解压压缩包</li>
            <li>📜 日志历史：按服务器拆分日志，历史记录可回溯、重新部署</li>
            <li>📚 脚本库：可复用的远程命令片段，支持参数化、上下文插值与危险确认</li>
            <li>🖥️ SSH 终端：一键打开远程服务器终端，协议层认证真正免密登录</li>
        </ul>
    ]]></description>

    <idea-version since-build="223" until-build="262.*"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <resource-bundle>messages.DeployXBundle</resource-bundle>

    <!-- ============================================================ -->
    <!--                        EXTENSIONS                             -->
    <!-- ============================================================ -->
    <extensions defaultExtensionNs="com.intellij">

        <!-- Application Services -->
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.config.ConfigManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.config.FileSyncSettings"/>
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.service.ServerManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.service.MappingManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.service.ScriptManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.service.SyncService"/>
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.service.DeployService"/>
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.service.HistoryManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.deploy.service.TerminalService"/>

        <!-- Settings Page -->
        <applicationConfigurable
            parentId="tools"
            instance="com.alianga.idea.deploy.ui.settings.FileSyncSettingsConfigurable"
            id="com.alianga.idea.deploy.settings"
            displayName="DeployX"/>

        <!-- Language Settings Page (child of DeployX settings) -->
        <!-- 使用 key 属性（而非 displayName="%key"）声明本地化显示名：
             ConfigurableEP 对 % 前缀不做解析，displayName="%key" 会原样显示；
             key 属性由平台从 <resource-bundle> 按 IDE Locale 解析，避免异常
             且正确显示 "Language" / "语言"。 -->
        <applicationConfigurable
            parentId="com.alianga.idea.deploy.settings"
            instance="com.alianga.idea.deploy.ui.settings.LanguageConfigurable"
            id="com.alianga.idea.deploy.languageSettings"
            key="settings.language.configurableName"/>

        <!-- Tool Window -->
        <toolWindow
            id="DeployX"
            icon="/icons/toolWindow.svg"
            factoryClass="com.alianga.idea.deploy.ui.toolwindow.FileSyncToolWindowFactory"
            anchor="right"/>

        <!-- Notification Group -->
        <notificationGroup id="DeployX"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

    </extensions>

    <!-- ============================================================ -->
    <!--                         ACTIONS                               -->
    <!-- ============================================================ -->
    <actions>
        <!-- Sync File Action -->
        <action id="FileSync.SyncFile"
                class="com.alianga.idea.deploy.action.SyncFileAction"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt Y"/>
        </action>

        <!-- Quick Push Action -->
        <action id="FileSync.QuickPush"
                class="com.alianga.idea.deploy.action.QuickPushAction"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift P"/>
        </action>

        <!-- Deploy Action -->
        <action id="FileSync.Deploy"
                class="com.alianga.idea.deploy.action.DeployAction"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <!-- Preview Sync Action -->
        <action id="FileSync.PreviewSync"
                class="com.alianga.idea.deploy.action.PreviewSyncAction"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <!-- Open SSH Terminal Action -->
        <action id="FileSync.OpenSshTerminal"
                class="com.alianga.idea.deploy.action.OpenSshTerminalAction"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt T"/>
        </action>

        <!-- Open Script Library Action -->
        <action id="FileSync.OpenScriptLibrary"
                class="com.alianga.idea.deploy.action.OpenScriptLibraryAction"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <!-- Run Script From Selection Action -->
        <action id="FileSync.RunScriptOnSelection"
                class="com.alianga.idea.deploy.action.RunScriptOnSelectionAction"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <!-- DeployX Submenu -->
        <group id="FileSync.MenuGroup"
               class="com.alianga.idea.deploy.action.DeployXMenuGroup"
               popup="true"
               icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>

            <reference id="FileSync.SyncFile"/>
            <reference id="FileSync.QuickPush"/>
            <separator/>
            <reference id="FileSync.Deploy"/>
            <reference id="FileSync.PreviewSync"/>
            <separator/>
            <reference id="FileSync.OpenSshTerminal"/>
            <separator/>
            <reference id="FileSync.OpenScriptLibrary"/>
            <reference id="FileSync.RunScriptOnSelection"/>
        </group>
    </actions>

</idea-plugin>
