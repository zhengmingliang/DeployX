<idea-plugin>
    <id>com.alianga.idea.filesync</id>
    <name>File Sync Tool</name>
    <vendor email="alianga@example.com" url="https://github.com/alianga">alianga</vendor>

    <description><![CDATA[
        <p>一键式文件同步部署工具，支持目录映射、跨平台传输、批量上传/部署、自动备份、远程解压和更新报告。</p>
        <ul>
            <li>🖥️ 服务器管理：支持密码/密钥 SSH 认证，支持连接测试与配置复制</li>
            <li>📁 目录映射：本地/远程目录映射，唯一 ID 管理，名称允许重复</li>
            <li>🔄 传输模式：rsync 优先，支持 AUTO / RSYNC_ONLY / SFTP_ONLY；rsync 不可用或 sshpass 缺失时可自动降级 SFTP</li>
            <li>📤 批量上传：多文件使用 rsync --files-from 合并传输，保持相对路径</li>
            <li>🚀 部署流程：Deploy 支持按分组执行一次备份、上传、解压和前后置命令</li>
            <li>💾 智能备份：支持备份源配置、压缩包备份和选择文件打包备份</li>
            <li>📦 智能解压：上传后可按配置解压压缩包</li>
            <li>📜 日志/历史/报告：按服务器拆分日志 Tab，支持历史记录、重新部署、复制/导出更新报告</li>
            <li>🖥️ SSH 终端：一键打开远程服务器 SSH 终端，支持密码和密钥认证</li>
        </ul>
    ]]></description>

    <idea-version since-build="223" until-build=""/>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <!-- ============================================================ -->
    <!--                        EXTENSIONS                             -->
    <!-- ============================================================ -->
    <extensions defaultExtensionNs="com.intellij">

        <!-- Application Services -->
        <applicationService
            serviceImplementation="com.alianga.idea.filesync.config.ConfigManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.filesync.config.FileSyncSettings"/>
        <applicationService
            serviceImplementation="com.alianga.idea.filesync.service.ServerManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.filesync.service.MappingManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.filesync.service.SyncService"/>
        <applicationService
            serviceImplementation="com.alianga.idea.filesync.service.DeployService"/>
        <applicationService
            serviceImplementation="com.alianga.idea.filesync.service.HistoryManager"/>
        <applicationService
            serviceImplementation="com.alianga.idea.filesync.service.TerminalService"/>

        <!-- Settings Page -->
        <applicationConfigurable
            parentId="tools"
            instance="com.alianga.idea.filesync.ui.settings.FileSyncSettingsConfigurable"
            id="com.alianga.idea.filesync.settings"
            displayName="File Sync Tool"/>

        <!-- Tool Window -->
        <toolWindow
            id="File Sync"
            icon="/icons/toolWindow.svg"
            factoryClass="com.alianga.idea.filesync.ui.toolwindow.FileSyncToolWindowFactory"
            anchor="right"/>

        <!-- Notification Group -->
        <notificationGroup id="File Sync Tool"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

    </extensions>

    <!-- ============================================================ -->
    <!--                         ACTIONS                               -->
    <!-- ============================================================ -->
    <actions>
        <!-- Sync File Action -->
        <action id="FileSync.SyncFile"
                class="com.alianga.idea.filesync.action.SyncFileAction"
                text="Sync to Server"
                description="Sync selected file(s) to remote server"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt Y"/>
        </action>

        <!-- Quick Push Action -->
        <action id="FileSync.QuickPush"
                class="com.alianga.idea.filesync.action.QuickPushAction"
                text="Quick Push to Server"
                description="Quickly push selected file(s) to the matched server"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt shift P"/>
        </action>

        <!-- Deploy Action -->
        <action id="FileSync.Deploy"
                class="com.alianga.idea.filesync.action.DeployAction"
                text="Deploy (Backup + Upload + Unzip)"
                description="Full deployment workflow"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <!-- Preview Sync Action -->
        <action id="FileSync.PreviewSync"
                class="com.alianga.idea.filesync.action.PreviewSyncAction"
                text="Preview Sync"
                description="Preview which files would be transferred"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <!-- File Sync Submenu -->
        <group id="FileSync.MenuGroup"
               text="File Sync Tool"
               description="File sync operations"
               popup="true"
               icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>

            <reference id="FileSync.SyncFile"/>
            <reference id="FileSync.QuickPush"/>
            <separator/>
            <reference id="FileSync.Deploy"/>
            <reference id="FileSync.PreviewSync"/>
            <separator/>
            <reference id="FileSync.OpenSshTerminal"/>
        </group>

        <!-- Open SSH Terminal Action -->
        <action id="FileSync.OpenSshTerminal"
                class="com.alianga.idea.filesync.action.OpenSshTerminalAction"
                text="Open SSH Terminal"
                description="Open SSH terminal to remote server"
                icon="/icons/toolWindow.svg">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt T"/>
        </action>
    </actions>

</idea-plugin>
